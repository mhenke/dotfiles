{
  "$schema": "https://opencode.ai/config.json",
  
  // Custom plugins (uncomment if you want to use them)
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    [
      "opencode-runtime-fallback",
      {
        "notify_on_fallback": true,
        "retry_on_errors": [401, 402, 429, 500, 502, 503, 504],
        "timeout_seconds": 30,
        "cooldown_seconds": 30
      }
    ],
    "@tarquinen/opencode-dcp@latest",
    "claude-mem",
    "opencode-damage-control"
  ],
  
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "lighthouse": {
      "type": "local",
      "command": ["npx", "@danielsogl/lighthouse-mcp@latest"],
      "enabled": true
    }
  },
  

  "instructions": [],

  "permission": {
    "*": "ask",
    "read": {
      ".env": "deny",
      ".env.*": "deny",
      ".env.example": "allow"
    },
    "bash": {
      "*": "ask",
      "git *": "allow",
      "grep *": "allow",
      "ls *": "allow",
      "which *": "allow",
      "node *": "allow",
      "npm *": "allow",
      "npx *": "allow",
      "bun *": "allow",
      "mkdir *": "allow",
      "touch *": "allow",
      "sudo *": "deny",
      "chmod *": "deny",
      "chown *": "deny"
    },
    "edit": "ask",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "task": "allow",
    "skill": "allow"
  },

  "disabled_providers": [
    "github-models",
    "github-copilot",
    "openrouter"
  ],
  
  "default_agent": "plan",
  
  "agent": {
    "ask": { "disable": true },
    "architect": { "disable": true }
  },
  
  "provider": {
    "deepseek": {},
    "ollama": {
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434"
      },
      "models": {
        "qwen3.6:35b-a3b": {
          "name": "Qwen 3.6 (35b-A3B)",
          "limit": { "context": 262144, "output": 65536 }
        },
        "gemma4:12b": {
          "name": "Gemma 4 (12b)",
          "limit": { "context": 262144, "output": 8192 }
        },
        "gemma4:latest": {
          "name": "Gemma 4 (latest)",
          "limit": { "context": 32000, "output": 8192 }
        }
      }
    },
    "siliconflow": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "SiliconFlow",
      "options": {
        "baseURL": "https://api.siliconflow.com/v1"
      },
      "models": {
        "deepseek-ai/DeepSeek-V4-Flash": {
          "name": "DeepSeek V4 Flash",
          "limit": { "context": 65536, "output": 8192 }
        },
        "moonshotai/Kimi-K2.6": {
          "name": "Kimi K2.6",
          "limit": { "context": 131072, "output": 8192 }
        },
        "MiniMaxAI/MiniMax-M3": {
          "name": "MiniMax M3",
          "limit": { "context": 262144, "output": 65536 }
        }
      }
    },
    "opencode": {
      "models": {
        "gpt-5.5": {
          "name": "GPT 5.5",
          "limit": { "context": 272000, "output": 65536 }
        },
        "gpt-5.4": {
          "name": "GPT 5.4",
          "limit": { "context": 272000, "output": 65536 }
        },
        "gpt-5.4-mini": {
          "name": "GPT 5.4 Mini",
          "limit": { "context": 128000, "output": 16384 }
        },
        "claude-opus-4.8": {
          "name": "Claude Opus 4.8",
          "limit": { "context": 200000, "output": 8192 }
        },
        "minimax-m3": {
          "name": "MiniMax M3",
          "limit": { "context": 262144, "output": 65536 }
        },
        "kimi-k2.6": {
          "name": "Kimi K2.6",
          "limit": { "context": 131072, "output": 8192 }
        },
        "glm-5.1": {
          "name": "GLM-5.1",
          "limit": { "context": 131072, "output": 8192 }
        },
        "deepseek-v4-flash-free": {
          "name": "DeepSeek V4 Flash Free",
          "limit": { "context": 65536, "output": 8192 }
        }
      }
    }
  }
}