{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/glm-5.1",
  "small_model": "opencode/deepseek-v4-flash-free",
  "instructions": [
    "/home/mhenke/dotfiles/opencode/.config/opencode/instructions/global.md"
  ],
  "plugin": [
    "./plugins/claude-mem.js",
    "oh-my-opencode-slim"
  ],
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "lighthouse": {
      "type": "local",
      "command": [
        "npx",
        "@danielsogl/lighthouse-mcp@latest"
      ],
      "enabled": false
    }
  },
  "permission": {
    "*": "ask",
    "read": {
      ".env": "deny",
      ".env.*": "deny",
      ".env.example": "allow"
    },
    "bash": {
      "*": "ask",
      "rm *": "ask",
      "rm -rf *": "deny",
      "rmdir *": "ask",
      "dd *": "ask",
      "mkfs*": "deny",
      "fdisk *": "deny",
      "git *": "allow",
      "grep *": "allow",
      "ls *": "allow",
      "which *": "allow",
      "node *": "allow",
      "npm *": "allow",
      "npx *": "allow",
      "bun *": "allow",
      "mkdir *": "allow",
      "touch *": "allow",
      "sudo *": "deny",
      "chmod *": "deny",
      "chown *": "deny"
    },
    "edit": "ask",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "task": "allow",
    "skill": "allow"
  },
  "disabled_providers": [
    "github-models",
    "github-copilot",
    "openrouter"
  ],
  "default_agent": "plan",
  "agent": {
    "build": {
      "disable": false
    },
    "plan": {
      "mode": "primary",
      "disable": false
    },
    "alpha": {
      "disable": true
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "provider": {
    "deepseek": {},
    "ollama": {
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3.6:35b-a3b": {
          "name": "Qwen 3.6 (35b-A3B)",
          "limit": {
            "context": 262144,
            "output": 65536
          }
        },
        "gemma4:12b": {
          "name": "Gemma 4 (12b)",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        },
        "gemma4:latest": {
          "name": "Gemma 4 (latest)",
          "limit": {
            "context": 32000,
            "output": 8192
          }
        }
      }
    },
    "opencode": {}
  },
  "lsp": true
}
