{
  "$schema": "https://unpkg.com/oh-my-opencode-slim@latest/oh-my-opencode-slim.schema.json",
  "preset": "balanced",
  "autoUpdate": true,
  "setDefaultAgent": true,
  "scoringEngineVersion": "v2",
  "multiplexer": {
    "type": "tmux",
    "layout": "main-vertical",
    "main_pane_size": 60
  },
  "presets": {
    "zen": {
      "orchestrator": {
        "model": [
          "opencode/deepseek-v4-flash-free",
          "opencode/deepseek-v4-flash",
          "opencode/nemotron-3-ultra-free"
        ],
        "variant": "medium",
        "skills": ["*"],
        "mcps": ["*", "!context7"]
      },
      "oracle": {
        "model": [
          "deepseek/deepseek-v4-pro",
          "opencode/deepseek-v4-pro",
          "opencode/claude-sonnet-4"
        ],
        "variant": "max",
        "skills": ["simplify"],
        "mcps": []
      },
      "librarian": {
        "model": [
          "opencode/mimo-v2.5-free",
          "opencode/north-mini-code-free"
        ],
        "skills": [],
        "mcps": ["websearch", "context7", "gh_grep"]
      },
      "explorer": {
        "model": [
          "opencode/deepseek-v4-flash-free",
          "opencode/deepseek-v4-flash"
        ],
        "skills": [],
        "mcps": []
      },
      "designer": {
        "model": [
          "opencode/kimi-k2.6",
          "opencode/kimi-k2.5"
        ],
        "variant": "medium",
        "skills": [],
        "mcps": []
      },
      "fixer": {
        "model": [
          "opencode/deepseek-v4-flash-free",
          "opencode/deepseek-v4-flash"
        ],
        "variant": "high",
        "skills": [],
        "mcps": []
      },
      "observer": {
        "model": [
          "opencode/mimo-v2.5-free",
          "opencode/nemotron-3-ultra-free"
        ],
        "variant": "low",
        "skills": [],
        "mcps": []
      }
    },
    "go": {
      "orchestrator": {
        "model": [
          "opencode-go/glm-5.1",
          "opencode-go/qwen3.7-plus",
          "opencode/deepseek-v4-flash-free"
        ],
        "skills": ["*"],
        "mcps": ["*", "!context7"]
      },
      "oracle": {
        "model": [
          "deepseek/deepseek-v4-pro",
          "opencode-go/deepseek-v4-pro",
          "opencode/deepseek-v4-pro"
        ],
        "variant": "max",
        "skills": ["simplify"],
        "mcps": []
      },
      "librarian": {
        "model": [
          "opencode-go/minimax-m2.7",
          "opencode-go/mimo-v2.5-pro",
          "opencode/mimo-v2.5-free"
        ],
        "skills": [],
        "mcps": ["websearch", "context7", "gh_grep"]
      },
      "explorer": {
        "model": [
          "opencode-go/minimax-m2.7",
          "opencode-go/deepseek-v4-flash",
          "opencode/deepseek-v4-flash-free"
        ],
        "skills": [],
        "mcps": []
      },
      "designer": {
        "model": [
          "opencode-go/kimi-k2.6",
          "opencode/kimi-k2.6"
        ],
        "variant": "medium",
        "skills": [],
        "mcps": []
      },
      "fixer": {
        "model": [
          "opencode-go/deepseek-v4-flash",
          "deepseek/deepseek-v4-flash",
          "opencode/deepseek-v4-flash-free"
        ],
        "variant": "high",
        "skills": [],
        "mcps": []
      },
      "observer": {
        "model": [
          "opencode-go/kimi-k2.6",
          "opencode-go/minimax-m2.7",
          "opencode/mimo-v2.5-free"
        ],
        "variant": "low",
        "skills": [],
        "mcps": []
      }
    },
    "balanced": {
      "orchestrator": {
        "model": [
          "opencode/mimo-v2.5-free",
          "opencode-go/mimo-v2.5",
          "nvidia/moonshotai/kimi-k2.6",
          "deepseek/deepseek-v4-pro"
        ],
        "temperature": 0.4,
        "skills": ["*"],
        "mcps": ["*", "!context7"]
