{
  "$schema": "https://unpkg.com/oh-my-opencode-slim@latest/oh-my-opencode-slim.schema.json",
  "preset": "balanced",
  "autoUpdate": true,
  "setDefaultAgent": true,
  "scoringEngineVersion": "v2",
  "multiplexer": {
    "type": "tmux",
    "layout": "main-vertical",
    "main_pane_size": 60
  },
  "presets": {
    "zen": {
      "orchestrator": {
        "model": [
          "opencode/deepseek-v4-flash-free",
          "opencode/deepseek-v4-flash",
          "opencode/nemotron-3-ultra-free"
        ],
        "variant": "medium",
        "skills": ["*"],
        "mcps": ["*", "!context7"]
      },
      "oracle": {
        "model": [
          "opencode/deepseek-v4-pro",
          "deepseek/deepseek-v4-pro",
          "opencode/claude-sonnet-4"
        ],
        "variant": "max",
        "skills": ["simplify"],
        "mcps": []
      },
      "librarian": {
        "model": [
          "opencode/mimo-v2.5-free",
          "opencode/north-mini-code-free"
        ],
        "skills": [],
        "mcps": ["websearch", "context7", "grep_app"]
      },
      "explorer": {
        "model": [
          "opencode/deepseek-v4-flash-free",
          "opencode/deepseek-v4-flash"
        ],
        "skills": [],
        "mcps": []
      },
      "designer": {
        "model": [
          "opencode/kimi-k2.6",
          "opencode/kimi-k2.5"
        ],
        "variant": "medium",
        "skills": [],
        "mcps": []
      },
      "fixer": {
        "model": [
          "opencode/deepseek-v4-flash-free",
          "opencode/deepseek-v4-flash"
        ],
        "variant": "high",
        "skills": [],
        "mcps": []
      },
      "observer": {
        "model": [
          "opencode/mimo-v2.5-free",
          "opencode/nemotron-3-ultra-free"
        ],
        "variant": "low",
        "skills": [],
        "mcps": []
      }
    },
    "go": {
      "orchestrator": {
        "model": [
          "opencode-go/glm-5.1",
          "opencode-go/qwen3.7-plus",
          "opencode/deepseek-v4-flash-free"
        ],
        "skills": ["*"],
        "mcps": ["*", "!context7"]
      },
      "oracle": {
        "model": [
          "opencode-go/deepseek-v4-pro",
          "deepseek/deepseek-v4-pro",
          "opencode/deepseek-v4-pro"
        ],
        "variant": "max",
        "skills": ["simplify"],
        "mcps": []
      },
      "librarian": {
        "model": [
          "opencode-go/minimax-m2.7",
          "opencode-go/mimo-v2.5-pro",
          "opencode/mimo-v2.5-free"
        ],
        "skills": [],
        "mcps": ["websearch", "context7", "grep_app"]
      },
      "explorer": {
        "model": [
          "opencode-go/minimax-m2.7",
          "opencode-go/deepseek-v4-flash",
          "opencode/deepseek-v4-flash-free"
        ],
        "skills": [],
        "mcps": []
      },
      "designer": {
        "model": [
          "opencode-go/kimi-k2.6",
          "opencode/kimi-k2.6"
        ],
        "variant": "medium",
        "skills": [],
        "mcps": []
      },
      "fixer": {
        "model": [
          "opencode-go/deepseek-v4-flash",
          "deepseek/deepseek-v4-flash",
          "opencode/deepseek-v4-flash-free"
        ],
        "variant": "high",
        "skills": [],
        "mcps": []
      },
      "observer": {
        "model": [
          "opencode-go/kimi-k2.6",
          "opencode-go/minimax-m2.7",
          "opencode/mimo-v2.5-free"
        ],
        "variant": "low",
        "skills": [],
        "mcps": []
      }
    },
    "balanced": {
      "orchestrator": {
        "model": [
          "opencode-go/glm-5.1",
          "opencode-go/qwen3.7-plus",
          "opencode-go/mimo-v2.5-pro",
          "opencode/qwen3.6-plus",
          "opencode/deepseek-v4-flash",
          "opencode/deepseek-v4-flash-free"
        ]
      },
      "oracle": {
        "model": [
          "opencode-go/kimi-k2.7-code",
          "opencode-go/kimi-k2.6",
          "opencode-go/qwen3.7-max",
          "opencode-go/mimo-v2.5-pro",
          "deepseek/deepseek-v4-pro",
          "opencode/kimi-k2.6",
          "opencode/deepseek-v4-pro"
        ],
        "variant": "max"
      },
      "designer": {
        "model": [
          "opencode-go/kimi-k2.7-code",
          "opencode-go/kimi-k2.6",
          "opencode-go/mimo-v2.5-pro",
          "opencode-go/glm-5.1",
          "opencode/kimi-k2.6",
          "opencode/qwen3.6-plus"
        ],
        "variant": "medium"
      },
      "librarian": {
        "model": [
          "opencode/mimo-v2.5-free",
          "opencode-go/mimo-v2.5-pro",
          "opencode-go/qwen3.6-plus",
          "opencode/qwen3.6-plus"
        ]
      },
      "explorer": {
        "model": [
          "opencode/deepseek-v4-flash-free",
          "opencode-go/deepseek-v4-flash",
          "deepseek/deepseek-v4-flash",
          "opencode/deepseek-v4-flash"
        ]
      },
      "fixer": {
        "model": [
          "opencode/deepseek-v4-flash-free",
          "opencode-go/deepseek-v4-flash",
          "deepseek/deepseek-v4-flash",
          "opencode/deepseek-v4-flash"
        ],
        "variant": "high"
      },
      "observer": {
        "model": [
          "opencode/mimo-v2.5-free",
          "opencode-go/mimo-v2.5-pro",
          "opencode-go/minimax-m3",
          "opencode-go/qwen3.6-plus",
          "opencode/qwen3.6-plus",
          "opencode/deepseek-v4-flash-free"
        ],
        "variant": "low"
      }
    }
  },
  "council": {
    "presets": {
      "zen": {
        "alpha": {
          "model": "opencode/deepseek-v4-pro",
          "variant": "high"
        },
        "beta": {
          "model": "opencode/kimi-k2.6"
        },
        "gamma": {
          "model": "opencode/mimo-v2.5-free"
        }
      },
      "go": {
        "alpha": {
          "model": "opencode-go/kimi-k2.6",
          "variant": "medium"
        },
        "beta": {
          "model": "opencode-go/qwen3.7-plus",
          "variant": "medium"
        },
        "gamma": {
          "model": "opencode-go/deepseek-v4-flash",
          "variant": "high"
        }
      },
      "balanced": {
        "alpha": {
          "model": "opencode-go/kimi-k2.7-code",
          "variant": "high"
        },
        "beta": {
          "model": "opencode-go/glm-5.1",
          "variant": "medium"
        },
        "gamma": {
          "model": "opencode-go/minimax-m3"
        }
      }
    },
    "default_preset": "balanced",
    "councillor_execution_mode": "parallel"
  },
  "agents": {
    "council": {
      "model": "opencode-go/glm-5.1"
    },
    "councillor": {
      "model": "opencode-go/glm-5.1"
    }
  },
  "disabled_agents": [],
  "websearch": {
    "provider": "exa"
  },
  "todoContinuation": {
    "maxContinuations": 5,
    "cooldownMs": 3000,
    "autoEnable": true,
    "autoEnableThreshold": 3
  }
}