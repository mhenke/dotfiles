{
  "$schema": "https://unpkg.com/oh-my-opencode-slim@latest/oh-my-opencode-slim.schema.json",
  "compactSidebar": true,
  "preset": "balanced",
  "disabled_agents": [],
  "image_routing": "auto",
  "autoUpdate": true,
  "setDefaultAgent": true,
  "scoringEngineVersion": "v2",
  "presets": {
    "balanced": {
      "orchestrator": {
        "model": [
          "opencode/hy3-free",
          "opencode/mimo-v2.5-free",
          "opencode-go/minimax-m3",
          "opencode/minimax-m3"
        ],
        "temperature": 0.4,
        "skills": [
          "*"
        ],
        "mcps": [
          " ",
          "!context7"
        ]
      },
      "oracle": {
        "model": [
          "opencode/big-pickle",
          "opencode-go/deepseek-v4-pro",
          "opencode/deepseek-v4-pro"
        ],
        "temperature": 0.4,
        "variant": "max",
        "skills": [
          "simplify"
        ],
        "mcps": []
      },
      "designer": {
        "model": [
          "opencode-go/kimi-k2.7-code",
          "opencode/minimax-m3"
        ],
        "temperature": 0.3,
        "variant": "medium",
        "skills": [],
        "mcps": []
      },
      "librarian": {
        "model": [
          "opencode/mimo-v2.5-free",
          "opencode/north-mini-code-free",
          "opencode-go/mimo-v2.5",
          "opencode/minimax-m2.7"
        ],
        "temperature": 0.2,
        "skills": [],
        "mcps": [
          "websearch",
          "context7",
          "gh_grep"
        ]
      },
      "explorer": {
        "model": [
          "opencode/deepseek-v4-flash-free",
          "opencode/north-mini-code-free",
          "opencode-go/deepseek-v4-flash",
          "opencode/deepseek-v4-flash"
        ],
        "temperature": 0.2,
        "skills": [],
        "mcps": []
      },
      "fixer": {
        "model": [
          "opencode/deepseek-v4-flash-free",
          "opencode/north-mini-code-free",
          "opencode-go/deepseek-v4-flash",
          "opencode/deepseek-v4-flash"
        ],
        "temperature": 0.2,
        "variant": "high",
        "skills": [],
        "mcps": []
      },
      "observer": {
        "model": [
          "opencode/mimo-v2.5-free",
          "opencode-go/mimo-v2.5",
          "opencode/mimo-v2.5"
        ],
        "temperature": 0.2,
        "variant": "low",
        "skills": [],
        "mcps": []
      }
    },
    "opencode-zen-free": {
      "orchestrator": {
        "model": "opencode/hy3-free",
        "temperature": 0.4,
        "skills": [
          "*"
        ],
        "mcps": [
          " ",
          "!context7"
        ]
      },
      "oracle": {
        "model": "opencode/big-pickle",
        "temperature": 0.4,
        "variant": "max",
        "skills": [
          "simplify"
        ],
        "mcps": []
      },
      "explorer": {
        "model": "opencode/deepseek-v4-flash-free",
        "temperature": 0.2,
        "skills": [],
        "mcps": []
      },
      "librarian": {
        "model": "opencode/mimo-v2.5-free",
        "temperature": 0.2,
        "skills": [],
        "mcps": [
          "websearch",
          "context7",
          "gh_grep"
        ]
      },
      "designer": {
        "model": "opencode/mimo-v2.5-free",
        "temperature": 0.3,
        "variant": "medium",
        "skills": [],
        "mcps": []
      },
      "fixer": {
        "model": "opencode/deepseek-v4-flash-free",
        "temperature": 0.2,
        "variant": "high",
        "skills": [],
        "mcps": []
      },
      "observer": {
        "model": "opencode/mimo-v2.5-free",
        "temperature": 0.2,
        "variant": "low",
        "skills": [],
        "mcps": []
      }
    }
  },
  "council": {
    "presets": {
      "balanced": {
        "alpha": {
          "model": "opencode/big-pickle",
          "variant": "high",
          "fallback_models": [
            "opencode-go/deepseek-v4-pro",
            "opencode/deepseek-v4-pro"
          ]
        },
        "beta": {
          "model": "opencode-go/qwen3.7-plus",
          "variant": "high",
          "fallback_models": [
            "opencode/qwen3.7-plus"
          ]
        },
        "gamma": {
          "model": "opencode/mimo-v2.5-free",
          "variant": "high",
          "fallback_models": [
            "opencode-go/mimo-v2.5",
            "opencode/mimo-v2.5"
          ]
        }
      }
    },
    "default_preset": "balanced",
    "councillor_execution_mode": "parallel"
  },
  "agents": {
    "council": {
      "model": [
        "opencode/hy3-free",
        "opencode/mimo-v2.5-free",
        "opencode-go/minimax-m3",
        "opencode/minimax-m3"
      ]
    },
    "skeptic": {
      "model": [
        "opencode/big-pickle",
        "opencode-go/qwen3.7-plus",
        "opencode/qwen3.7-plus"
      ],
      "variant": "max",
      "prompt": "You are a structured critic. You aren't here to tear things down for sport \u2014 you make ideas prove they can survive contact with reality before they earn the greenlight. Before rendering any verdict, you always complete this protocol in order:\n\n1. Restate the idea or proposal in its strongest form \u2014 steel-man it. If you can't make it sound compelling, you haven't understood it yet.\n\n2. Failure conditions \u2014 list 2-4 concrete scenarios under which this fails, stalls, or isn't worth pursuing. Reference specific assumptions, edge cases, or implicit bets the proposal is making.\n\n3. Effort realism \u2014 estimate realistic effort versus what's being assumed. People are systematically optimistic here. Look for the 'three weeks pretending to be three days' pattern. What hidden costs are being ignored? (Setup, onboarding, maintenance, context-switching.)\n\n4. Required conditions \u2014 what would need to be true for this to succeed? Which of those can be validated cheaply right now? This isn't about belief \u2014 it's about testable hypotheses.\n\n5. Verdict and next step \u2014 based on the above, is this worth pursuing? What's the single most useful thing to do next?\n\nDo not skip steps. Do not disagree for its own sake \u2014 if the idea is genuinely sound, say so, but only after completing steps 1-4. Use concrete scenarios and assumptions, not abstract criticism."
    }
  },
  "websearch": {
    "provider": "exa"
  },
  "todoContinuation": {
    "maxContinuations": 5,
    "cooldownMs": 3000,
    "autoEnable": true,
    "autoEnableThreshold": 3
  },
  "multiplexer": {
    "type": "tmux"
  }
}