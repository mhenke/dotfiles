            "opencode/nemotron-3-ultra-free",
            "nvidia/z-ai/glm-5.2",
            "nvidia/glm-5.1"
          ]
        },
        "beta": {
          "model": "opencode-go/kimi-k2.7-code",
          "variant": "high",
          "fallback_models": [
            "opencode/mimo-v2.5-free",
            "nvidia/openai/gpt-oss-120b",
            "nvidia/moonshotai/kimi-k2.6"
          ]
        },
