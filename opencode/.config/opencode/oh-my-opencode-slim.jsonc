{
  "$schema": "https://unpkg.com/oh-my-opencode-slim@latest/oh-my-opencode-slim.schema.json",
  "preset": "balanced",
  "autoUpdate": true,
  "setDefaultAgent": true,
  "scoringEngineVersion": "v2",
  "multiplexer": {
    "type": "tmux",
    "layout": "main-vertical",
    "main_pane_size": 60
  },
  "presets": {
    "zen": {
      "orchestrator": {
        "model": [
          "opencode/deepseek-v4-flash-free",
          "opencode/deepseek-v4-flash",
          "opencode/nemotron-3-ultra-free"
        ],
        "variant": "medium",
        "skills": ["*"],
        "mcps": ["*", "!context7"]
      },
      "oracle": {
        "model": [
          "deepseek/deepseek-v4-pro",
          "opencode/deepseek-v4-pro",
          "opencode/claude-sonnet-4"
        ],
        "variant": "max",
        "skills": ["simplify"],
        "mcps": []
      },
      "librarian": {
        "model": [
          "opencode/mimo-v2.5-free",
          "opencode/north-mini-code-free"
        ],
        "skills": [],
        "mcps": ["websearch", "context7", "gh_grep"]
      },
      "explorer": {
        "model": [
          "opencode/deepseek-v4-flash-free",
          "opencode/deepseek-v4-flash"
        ],
        "skills": [],
        "mcps": []
      },
      "designer": {
        "model": [
          "opencode/kimi-k2.6",
          "opencode/kimi-k2.5"
        ],
        "variant": "medium",
        "skills": [],
        "mcps": []
      },
      "fixer": {
        "model": [
          "opencode/deepseek-v4-flash-free",
          "opencode/deepseek-v4-flash"
        ],
        "variant": "high",
        "skills": [],
        "mcps": []
      },
      "observer": {
        "model": [
          "opencode/mimo-v2.5-free",
          "opencode/nemotron-3-ultra-free"
        ],
        "variant": "low",
        "skills": [],
        "mcps": []
      }
    },
    "go": {
      "orchestrator": {
        "model": [
          "opencode-go/glm-5.1",
          "opencode-go/qwen3.7-plus",
          "opencode/deepseek-v4-flash-free"
        ],
        "skills": ["*"],
        "mcps": ["*", "!context7"]
      },
      "oracle": {
        "model": [
          "deepseek/deepseek-v4-pro",
          "opencode-go/deepseek-v4-pro",
          "opencode/deepseek-v4-pro"
        ],
        "variant": "max",
        "skills": ["simplify"],
        "mcps": []
      },
      "librarian": {
        "model": [
          "opencode-go/minimax-m2.7",
          "opencode-go/mimo-v2.5-pro",
          "opencode/mimo-v2.5-free"
        ],
        "skills": [],
        "mcps": ["websearch", "context7", "gh_grep"]
      },
      "explorer": {
        "model": [
          "opencode-go/minimax-m2.7",
          "opencode-go/deepseek-v4-flash",
          "opencode/deepseek-v4-flash-free"
        ],
        "skills": [],
        "mcps": []
      },
      "designer": {
        "model": [
          "opencode-go/kimi-k2.6",
          "opencode/kimi-k2.6"
        ],
        "variant": "medium",
        "skills": [],
        "mcps": []
      },
      "fixer": {
        "model": [
          "opencode-go/deepseek-v4-flash",
          "deepseek/deepseek-v4-flash",
          "opencode/deepseek-v4-flash-free"
        ],
        "variant": "high",
        "skills": [],
        "mcps": []
      },
      "observer": {
        "model": [
          "opencode-go/kimi-k2.6",
          "opencode-go/minimax-m2.7",
          "opencode/mimo-v2.5-free"
        ],
        "variant": "low",
        "skills": [],
        "mcps": []
      }
    },
    "balanced": {
      "orchestrator": {
        "model": [
          "opencode/mimo-v2.5-free",
          "opencode-go/mimo-v2.5",
          "nvidia/z-ai/glm-5.1",
          "deepseek/deepseek-v4-pro"
        ],
        "temperature": 0.4,
        "skills": ["*"],
        "mcps": ["*", "!context7"]
      },
      "oracle": {
        "model": [
          "opencode-go/kimi-k2.7-code",
          "opencode/kimi-k2.6",
          "nvidia/mistralai/mistral-large-3",
          "deepseek/deepseek-v4-pro"
        ],
        "temperature": 0.4,
        "variant": "max",
        "skills": ["simplify"],
        "mcps": []
      },
      "designer": {
        "model": [
          "opencode-go/kimi-k2.7-code",
          "opencode/qwen3.6-plus",
          "nvidia/moonshotai/kimi-k2-instruct",
          "deepseek/deepseek-v4-pro"
        ],
        "temperature": 0.3,
        "variant": "medium",
        "skills": [],
        "mcps": []
      },
      "librarian": {
        "model": [
          "opencode/mimo-v2.5-free",
          "opencode-go/mimo-v2.5",
          "nvidia/qwen/qwen3.5-122b-a10b",
          "deepseek/deepseek-v4-flash"
        ],
        "temperature": 0.2,
        "skills": [],
        "mcps": ["websearch", "context7", "gh_grep"]
      },
      "explorer": {
        "model": [
          "opencode/deepseek-v4-flash-free",
          "opencode-go/deepseek-v4-flash",
          "nvidia/deepseek-ai/deepseek-v4-flash",
          "deepseek/deepseek-v4-flash"
        ],
        "temperature": 0.2,
        "skills": [],
        "mcps": []
      },
      "fixer": {
        "model": [
          "opencode/deepseek-v4-flash-free",
          "opencode-go/deepseek-v4-flash",
          "nvidia/minimaxai/minimax-m2.7",
          "deepseek/deepseek-v4-flash"
        ],
        "temperature": 0.2,
        "variant": "high",
        "skills": [],
        "mcps": []
      },
      "observer": {
        "model": [
          "opencode-go/qwen3.7-plus",
          "opencode/qwen3.6-plus",
          "nvidia/meta/llama-3.2-90b-vision-instruct",
          "deepseek/deepseek-v4-pro"
        ],
        "temperature": 0.2,
        "variant": "low",
        "skills": [],
        "mcps": []
      }
    }
  },
  "council": {
    "presets": {
      "zen": {
        "alpha": {
          "model": "opencode/deepseek-v4-pro",
          "variant": "high"
        },
        "beta": {
          "model": "opencode/kimi-k2.6"
        },
        "gamma": {
          "model": "opencode/mimo-v2.5-free"
        }
      },
      "go": {
        "alpha": {
          "model": "opencode-go/kimi-k2.6",
          "variant": "medium"
        },
        "beta": {
          "model": "opencode-go/qwen3.7-plus",
          "variant": "medium"
        },
        "gamma": {
          "model": "opencode-go/deepseek-v4-flash",
          "variant": "high"
        }
      },
      "balanced": {
        "alpha": {
          "model": "nvidia/glm-5.1",
          "variant": "high",
          "fallback_models": [
            "opencode-go/kimi-k2.7-code",
            "opencode/kimi-k2.6",
            "deepseek/deepseek-v4-pro"
          ]
        },
        "beta": {
          "model": "nvidia/nemotron-3-ultra-550b-a55b",
          "variant": "high",
          "fallback_models": [
            "opencode-go/minimax-m3",
            "opencode/qwen3.6-plus",
            "deepseek/deepseek-v4-pro"
          ]
        },
        "gamma": {
          "model": "nvidia/deepseek-v4-flash",
          "variant": "medium",
          "fallback_models": [
            "opencode/mimo-v2.5-free",
            "opencode-go/qwen3.7-max",
            "deepseek/deepseek-v4-flash"
          ]
        }
      }
    },
    "default_preset": "balanced",
    "councillor_execution_mode": "parallel"
  },
  "agents": {
    "council": {
      "model": ["opencode/mimo-v2.5-free", "opencode-go/mimo-v2.5", "deepseek/deepseek-v4-pro"]
    }
  },
  "disabled_agents": [],
  "websearch": {
    "provider": "exa"
  },
  "todoContinuation": {
    "maxContinuations": 5,
    "cooldownMs": 3000,
    "autoEnable": true,
    "autoEnableThreshold": 3
  }
}