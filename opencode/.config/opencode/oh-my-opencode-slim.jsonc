      "model": [
        "opencode-go/mimo-v2.5",
        "opencode/mimo-v2.5-free",
        "nvidia/z-ai/glm-5.2"
      ]
    }
  },
  
  "websearch": {
    "provider": "exa"
  },
  "todoContinuation": {
    "maxContinuations": 5,
    "cooldownMs": 3000,
    "autoEnable": true,
    "autoEnableThreshold": 3
  }
