{
  "$schema": "https://unpkg.com/oh-my-opencode-slim@latest/oh-my-opencode-slim.schema.json",
  "compactSidebar": true,
  "preset": "balanced",
  "disabled_agents": [],
  "image_routing": "auto",
  "autoUpdate": true,
  "setDefaultAgent": true,
  "scoringEngineVersion": "v2",
  "presets": {
    "balanced": {
      "orchestrator": {
        "model": [
          "opencode/mimo-v2.5-free",
          "opencode/north-mini-code-free",
          "opencode/laguna-s-2.1-free",
          "nvidia/stepfun-ai/step-3.7-flash",
          "nvidia/mistralai/mistral-small-4-119b-2603",
          "nvidia/nvidia/nemotron-3-super-120b-a12b",
          "opencode-go/minimax-m3",
          "opencode/minimax-m3"
        ],
        "temperature": 0.4,
        "skills": [
          "*"
        ],
        "mcps": [
          " ",
          "!context7"
        ]
      },
      "oracle": {
        "model": [
          "opencode/big-pickle",
          "opencode/nemotron-3-ultra-free",
          "nvidia/z-ai/glm-5.2",
          "nvidia/minimaxai/minimax-m3",
          "nvidia/mistralai/mistral-nemotron",
          "opencode-go/deepseek-v4-pro",
          "deepseek/deepseek-v4-pro"
        ],
        "temperature": 0.4,
        "variant": "high",
        "skills": [
          "simplify"
        ],
        "mcps": []
      },
      "designer": {
        "model": [
          "opencode-go/kimi-k2.7-code",
          "opencode/minimax-m3"
        ],
        "temperature": 0.3,
        "skills": [],
        "mcps": []
      },
      "librarian": {
        "model": [
          "opencode/mimo-v2.5-free",
          "opencode/north-mini-code-free",
          "opencode-go/mimo-v2.5",
          "opencode/minimax-m2.7"
        ],
        "temperature": 0.2,
        "skills": [],
        "mcps": [
          "websearch",
          "context7",
          "gh_grep"
        ]
      },
      "explorer": {
        "model": [
          "opencode/deepseek-v4-flash-free",
          "opencode/laguna-s-2.1-free",
          "opencode/north-mini-code-free",
          "opencode-go/deepseek-v4-flash",
          "opencode/deepseek-v4-flash"
        ],
        "temperature": 0.2,
        "skills": [],
        "mcps": []
      },
      "fixer": {
        "model": [
          "opencode/deepseek-v4-flash-free",
          "opencode/laguna-s-2.1-free",
          "opencode/north-mini-code-free",
          "opencode-go/deepseek-v4-flash",
          "opencode/deepseek-v4-flash"
        ],
        "temperature": 0.2,
        "skills": [],
        "mcps": []
      },
      "observer": {
        "model": [
          "opencode/mimo-v2.5-free",
          "opencode-go/mimo-v2.5",
          "opencode/mimo-v2.5"
        ],
        "temperature": 0.2,
        "skills": [],
        "mcps": []
      },
      "council": {
        "model": [
          "opencode/mimo-v2.5-free",
          "opencode-go/minimax-m3",
          "opencode/minimax-m3"
        ]
      },
      "skeptic": {
        "model": [
          "opencode/big-pickle",
          "opencode-go/qwen3.7-plus",
          "opencode/qwen3.7-plus"
        ],
        "variant": "max",
        "prompt": "You are a structured critic. You aren't here to tear things down for sport — you make ideas prove they can survive contact with reality before they earn the greenlight. Before rendering any verdict, you always complete this protocol in order:\n\n1. Restate the idea or proposal in its strongest form — steel-man it. If you can't make it sound compelling, you haven't understood it yet.\n\n2. Failure conditions — list 2-4 concrete scenarios under which this fails, stalls, or isn't worth pursuing. Reference specific assumptions, edge cases, or implicit bets the proposal is making.\n\n3. Effort realism — estimate realistic effort versus what's being assumed. People are systematically optimistic here. Look for the 'three weeks pretending to be three days' pattern. What hidden costs are being ignored? (Setup, onboarding, maintenance, context-switching.)\n\n4. Required conditions — what would need to be true for this to succeed? Which of those can be validated cheaply right now? This isn't about belief — it's about testable hypotheses.\n\n5. Verdict and next step — based on the above, is this worth pursuing? What's the single most useful thing to do next?\n\nDo not skip steps. Do not disagree for its own sake — if the idea is genuinely sound, say so, but only after completing steps 1-4. Use concrete scenarios and assumptions, not abstract criticism."
      }
    },
    "nvidia-free": {
      "orchestrator": {
        "model": [
          "nvidia/stepfun-ai/step-3.7-flash",
          "nvidia/mistralai/mistral-small-4-119b-2603",
          "nvidia/nvidia/nemotron-3-super-120b-a12b"
        ],
        "temperature": 0.4,
        "skills": [
          "*"
        ],
        "mcps": [
          " ",
