{
  "$schema": "https://unpkg.com/oh-my-opencode-slim@latest/oh-my-opencode-slim.schema.json",
  "preset": "opencode-go",
  "autoUpdate": true,
  "setDefaultAgent": true,
  "scoringEngineVersion": "v2",
  "presets": {
    "opencode-zen": {
      "orchestrator": {
        "model": "opencode/deepseek-v4-flash-free",
        "variant": "medium",
        "skills": ["*"],
        "mcps": ["*", "!context7"]
      },
      "oracle": {
        "model": "opencode/deepseek-v4-pro",
        "variant": "max",
        "skills": ["simplify"],
        "mcps": []
      },
      "librarian": {
        "model": "opencode/mimo-v2.5-free",
        "skills": [],
        "mcps": ["websearch", "context7", "grep_app"]
      },
      "explorer": {
        "model": "opencode/deepseek-v4-flash-free",
        "skills": [],
        "mcps": []
      },
      "designer": {
        "model": "opencode/kimi-k2.6",
        "variant": "medium",
        "skills": [],
        "mcps": []
      },
      "fixer": {
        "model": "opencode/deepseek-v4-flash-free",
        "variant": "high",
        "skills": [],
        "mcps": []
      },
      "observer": {
        "model": "opencode/mimo-v2.5-free",
        "skills": [],
        "mcps": []
      },
      "council": {
        "model": "opencode/deepseek-v4-flash",
        "variant": "high",
        "skills": [],
        "mcps": []
      }
    },
    "opencode-go": {
      "orchestrator": {
        "model": [
          "opencode-go/glm-5.1",
          "siliconflow/THUDM/GLM-Z1-5.1",
          "opencode/deepseek-v4-flash-free"
        ],
        "skills": ["*"],
        "mcps": ["*", "!context7"]
      },
      "oracle": {
        "model": [
          "opencode-go/deepseek-v4-pro",
          "siliconflow/deepseek-ai/DeepSeek-V4-Pro",
          "deepseek/deepseek-v4-pro",
          "opencode/deepseek-v4-pro"
        ],
        "variant": "max",
        "skills": ["simplify"],
        "mcps": []
      },
      "council": {
        "model": [
          "opencode-go/deepseek-v4-pro",
          "siliconflow/deepseek-ai/DeepSeek-V4-Pro",
          "deepseek/deepseek-v4-pro",
          "opencode/deepseek-v4-flash"
        ],
        "variant": "high",
        "skills": [],
        "mcps": []
      },
      "librarian": {
        "model": [
          "opencode-go/minimax-m2.7",
          "siliconflow/MiniMaxAI/MiniMax-M3",
          "opencode/mimo-v2.5-free"
        ],
        "skills": [],
        "mcps": ["websearch", "context7", "grep_app"]
      },
      "explorer": {
        "model": [
          "opencode-go/minimax-m2.7",
          "siliconflow/deepseek-ai/DeepSeek-V4-Flash",
          "deepseek/deepseek-v4-flash",
          "opencode/deepseek-v4-flash-free"
        ],
        "skills": [],
        "mcps": []
      },
      "designer": {
        "model": [
          "opencode-go/kimi-k2.6",
          "siliconflow/moonshotai/Kimi-K2.6",
          "opencode/kimi-k2.6"
        ],
        "variant": "medium",
        "skills": [],
        "mcps": []
      },
      "fixer": {
        "model": [
          "opencode-go/deepseek-v4-flash",
          "siliconflow/deepseek-ai/DeepSeek-V4-Flash",
          "deepseek/deepseek-v4-flash",
          "opencode/deepseek-v4-flash-free"
        ],
        "variant": "high",
        "skills": [],
        "mcps": []
      },
      "observer": {
        "model": [
          "opencode-go/kimi-k2.6",
          "siliconflow/MiniMaxAI/MiniMax-M3",
          "opencode/mimo-v2.5-free"
        ],
        "variant": "medium",
        "skills": [],
        "mcps": []
      }
    }
  },
  "council": {
    "presets": {
      "opencode-zen": {
        "alpha": {
          "model": "opencode/deepseek-v4-pro",
          "variant": "high"
        },
        "beta": {
          "model": "opencode/kimi-k2.6"
        },
        "gamma": {
          "model": "opencode/mimo-v2.5-free"
        }
      },
      "opencode-go": {
        "alpha": {
          "model": "opencode-go/kimi-k2.6",
          "variant": "medium"
        },
        "beta": {
          "model": "opencode-go/qwen3.7-plus",
          "variant": "medium"
        },
        "gamma": {
          "model": "opencode-go/deepseek-v4-flash",
          "variant": "high"
        }
      }
    },
    "default_preset": "opencode-go",
    "councillor_execution_mode": "parallel"
  },
  "disabled_agents": [],
  "websearch": {
    "provider": "exa"
  },
  "todoContinuation": {
    "maxContinuations": 5,
    "cooldownMs": 3000,
    "autoEnable": true,
    "autoEnableThreshold": 3
  }
}
